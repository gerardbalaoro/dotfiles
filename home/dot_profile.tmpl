# Load user environment variables
if [ -f "$HOME/.env" ]; then
  set -a
  . "$HOME/.env"
  set +a
fi

# Add the user's private bin if it exists
if [ -d "$HOME/bin" ] ; then
  export PATH="$HOME/bin:$PATH"
fi
if [ -d "$HOME/.local/bin" ] ; then
  export PATH="$HOME/.local/bin:$PATH"
fi

# If snap is installed, add snap bin to PATH
if command -v snap >/dev/null; then
  export PATH="/snap/bin:$PATH"
fi

{{- if eq .chezmoi.os "linux" }}
{{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}

# Initialize 1Password CLI from Windows
alias op=op.exe
{{- end }}
{{- end }}

# Initialize Homebrew
if command -v brew >/dev/null; then
  eval "$(brew shellenv)"
  if [ -f "$HOME/.local/bin/hb" ]; then
    brew() { "$HOME/.local/bin/hb" "$@"; }
  fi
fi

# Set default editor
if command -v code >/dev/null; then
  export EDITOR=code
fi

# Initialize shell integrations
SHELL_INTEGRATIONS="${XDG_DATA_HOME:-$HOME/.local/share}/shell-integrations"
install_shell_integrations() {
  (
    set -eu
    mkdir -p "$SHELL_INTEGRATIONS"

    for bin in bash zsh; do
      if command -v mise >/dev/null 2>&1; then
        mise completion "$bin" > "$SHELL_INTEGRATIONS/mise.$bin"

        if mise which bun >/dev/null 2>&1; then
          SHELL="/bin/$bin" mise exec -- bun completions > "$SHELL_INTEGRATIONS/bun.$bin"
        fi

        if mise which pnpm >/dev/null 2>&1; then
          mise exec -- pnpm completion "$bin" > "$SHELL_INTEGRATIONS/pnpm.$bin"
        fi
      fi

      if command -v fzf >/dev/null 2>&1; then
        fzf "--$bin" > "$SHELL_INTEGRATIONS/fzf.$bin"
      fi

      if command -v zoxide >/dev/null 2>&1; then
        zoxide init "$bin" > "$SHELL_INTEGRATIONS/zoxide.$_integration_shell"
      fi
    done
  )
}
load_shell_integrations() {
  if command -v oh-my-posh >/dev/null 2>&1; then
    eval "$(oh-my-posh init $1 --config "$HOME/.config/oh-my-posh/main.omp.json")"
  fi

  for f in "$SHELL_INTEGRATIONS"/*."$1"; do
    [ -r "$f" ] || continue
    . "$f"
  done
}
