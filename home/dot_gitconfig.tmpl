[user]
  name = Gerard Balaoro
  email = {{ onepasswordRead "op://Personal/SSH Key/email" }}
  signingkey = {{ joinPath .chezmoi.homeDir ".ssh/id_ed25519" }}
[gpg]
  format = ssh
[gpg "ssh"]
  allowedSignersFile = {{ joinPath .chezmoi.homeDir ".ssh/allowed_signers" }}
[commit]
  gpgsign = true
[core]
  editor = code --wait
{{- if eq .chezmoi.os "windows" }}
  fileMode = false
{{- end }}
[sequence]
  editor = code --wait
[init]
  defaultBranchName = main
[alias]
  cm = commit
  cmm = commit -i
  cmf = commit --fixup
  ca = commit --amend
  cam = commit --amend -m
  cane = commit --amend --no-edit
  rsu = reset @{u}
  rbi = rebase -i
  rbc = rebase --continue
  rba = rebase --abort
  rbs = rebase --autosquash
  co = checkout
  st = status
  br = branch
  lo = log --oneline --graph --decorate
  stu = stash --include-untracked
  stp = stash pop
  psf = push --force-with-lease
{{- if eq .chezmoi.os "linux" }}
{{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
[credential]
  helper = /mnt/c/Program\\ Files/Git/mingw64/bin/git-credential-manager.exe
{{- end }}
{{- end }}
{{- if eq .chezmoi.os "darwin" }}
[credential]
  helper = osxkeychain
{{- end }}
[push]
  autoSetupRemote = true
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
