{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.6",
  "small_model": "opencode-go/deepseek-v4-flash",
  "default_agent": "chat",
  "agent": {
    "chat": {
      "mode": "primary",
      "description": "A fast, general-purpose agent.",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "lead": {
      "mode": "all",
      "model": "openai/gpt-5.5",
      "description": "Plans, makes decisions, and coordinates work across agents.",
      "prompt": "{file:./prompts/lead.md}"
    },
    "code": {
      "mode": "subagent",
      "description": "Implements specific code changes from clear instructions.",
      "model": "opencode-go/kimi-k2.6",
      "prompt": "{file:./prompts/code.md}"
    },
    "review": {
      "mode": "subagent",
      "description": "Performs bounded code reviews from clear instructions.",
      "model": "opencode-go/kimi-k2.6",
      "prompt": "{file:./prompts/review.md}"
    },
    "research": {
      "mode": "subagent",
      "description": "Looks up docs, APIs, benchmarks, and current information.",
      "model": "opencode-go/kimi-k2.6",
      "prompt": "{file:./prompts/research.md}"
    }
  },
  "lsp": true,
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true,
      "oauth": {}
    }
  },
  "plugin": [
    "@slkiser/opencode-quota"
  ]
}
